{
  "name": "cubelinkelectron",
  "version": "3.4.3",
  "description": "CubeLink educational robotics studio by Eoreum",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "Eoreum",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "serialport": "^13.0.0"
  },
    "build": {
    "appId": "com.eoreum.cubelinkstudio",
    "productName": "CubeLink Studio",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web",
        "to": "web",
        "filter": [
          "**/*",
          "!**/*.bak",
          "!**/*.backup*",
          "!**/*.broken",
          "!**/*.tmp"
        ]
      }
    ],
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    },
    "portable": {
      "artifactName": "Cubelink_Studio.exe"
    }
  }

}
